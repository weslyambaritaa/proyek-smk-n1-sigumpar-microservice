# ========================================================
# nginx.conf — Konfigurasi API Gateway
# ========================================================
# Peran Nginx di sini:
# 1. Reverse Proxy: meneruskan request ke service yang tepat
# 2. Load Balancer: bisa dikembangkan ke multiple instance
# 3. CORS Handler: header CORS ditangani terpusat
# 4. Rate Limiting: mencegah abuse
# 5. Centralized Auth: Mengecek JWT Token sebelum tembus ke service
# ========================================================

# Jumlah worker process = jumlah CPU core
worker_processes auto;

events {
    # Maksimal koneksi simultan per worker
    worker_connections 1024;
}

http {
    # ── Logging ──────────────────────────────────────────────
    log_format main '$remote_addr - $remote_user [$time_local] '
                    '"$request" $status $body_bytes_sent '
                    '"$http_referer" "$http_user_agent" '
                    'rt=$request_time';

    access_log /var/log/nginx/access.log main;
    error_log  /var/log/nginx/error.log warn;
    client_max_body_size 50M;

    # ── Performance ──────────────────────────────────────────
    sendfile on;           # Kirim file langsung dari OS, tanpa buffer user-space
    keepalive_timeout 65;  # Pertahankan koneksi TCP selama 65 detik

    # Kompresi response untuk menghemat bandwidth
    gzip on;
    gzip_types application/json text/plain;
    gzip_min_length 1000;

    # ── Rate Limiting ─────────────────────────────────────────
    # Batasi 10 request per detik per IP
    limit_req_zone $binary_remote_addr zone=api_limit:10m rate=10r/s;

    # ── Cache Untuk Autentikasi (PENTING UNTUK PERFORMA) ──────
    # Mengalokasikan 10MB memori Nginx untuk mengingat token yang valid
    proxy_cache_path /var/cache/nginx keys_zone=token_cache:10m;

    # ── Upstream Definitions ──────────────────────────────────
    upstream backend_auth_service {
        server auth-service:3005;
    }
    upstream backend_academic_service {
        server academic-service:3003;
    }
    upstream backend_asset_service {
        server asset-service:3004;
    }
    upstream backend_learning_service {
        server learning-service:3006;
    }
    upstream backend_student_service {
        server student-service:3008;
    }
    upstream backend_vocational_service {
        server vocational-service:3007;
    }
    upstream frontend {
        server frontend:5173;
    }

    # ── Virtual Host / Server Block ───────────────────────────
    server {
        listen 80;
        server_name localhost;

        # ── CORS Headers (berlaku untuk semua route) ──────────
        add_header 'Access-Control-Allow-Origin'  '*' always;
        add_header 'Access-Control-Allow-Methods' 'GET, POST, PUT, DELETE, OPTIONS' always;
        add_header 'Access-Control-Allow-Headers' 'Content-Type, Authorization' always;

        # Handle preflight request (OPTIONS)
        if ($request_method = 'OPTIONS') {
            return 204;
        }

        # ── Health Check Nginx ────────────────────────────────
        location /health {
            return 200 '{"status":"OK","service":"api-gateway"}';
            add_header Content-Type application/json;
        }

        # ========================================================
        # ── INTERNAL ROUTE UNTUK CEK TOKEN (SATPM NGINX) ────────
        # ========================================================
        location = /auth-verify {
            internal; # Hanya bisa dipanggil oleh Nginx sendiri
            
            # Tembakkan ke route /verify di Auth Service
            proxy_pass http://auth-service:3005/api/auth/verify;
            
            # Matikan pengiriman body request agar cek token super cepat
            proxy_pass_request_body off;
            proxy_set_header Content-Length "";
            proxy_set_header X-Original-URI $request_uri;

            # --- Konfigurasi Caching Token ---
            proxy_cache token_cache;
            proxy_cache_key "$http_authorization"; # Ingat berdasarkan string token JWT-nya
            proxy_cache_valid 200 5m;              # Jika Token valid, ingat selama 5 menit
            proxy_cache_valid 401 403 0s;          # Jika gagal/susup, jangan diingat
        }

        # Custom response jika Nginx menolak token
        location = /error401 {
            default_type application/json;
            return 401 '{"error": "Unauthorized", "message": "Token tidak valid atau tidak ditemukan (Ditolak oleh Gateway)"}';
        }
        location = /error403 {
            default_type application/json;
            return 403 '{"error": "Forbidden", "message": "Akses ditolak (Ditolak oleh Gateway)"}';
        }


        # ========================================================
        # ── ROUTING MICROSERVICES ───────────────────────────────
        # ========================================================

        # ── Routing ke Auth Service (TIDAK ADA PENGAMAN) ──────
        # (Karena user butuh rute ini untuk login dan dapat token)
        location /api/auth {
            limit_req zone=api_limit burst=20 nodelay;
            proxy_pass http://auth-service:3005;
            
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # ── Routing ke Academic Service (DILINDUNGI) ──────────
        location /api/academic {
            auth_request /auth-verify;
            error_page 401 =401 /error401;
            error_page 403 =403 /error403;

            # 1. TANGKAP HEADER DARI AUTH-SERVICE
            auth_request_set $auth_user_id $upstream_http_x_user_id;
            auth_request_set $auth_user_role $upstream_http_x_user_role;

            # 2. SUNTIKKAN HEADER TERSEBUT KE ACADEMIC-SERVICE
            proxy_set_header X-User-Id $auth_user_id;
            proxy_set_header X-User-Role $auth_user_role;

            limit_req zone=api_limit burst=20 nodelay;
            proxy_pass http://academic-service:3003;
            
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # ── Routing ke Asset Service (DILINDUNGI) ─────────────
        location /api/asset {
            auth_request /auth-verify;
            error_page 401 =401 /error401;
            error_page 403 =403 /error403;

            limit_req zone=api_limit burst=20 nodelay;
            proxy_pass http://asset-service:3004;
            
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # ── Routing ke Learning Service (DILINDUNGI) ──────────
        location /api/learning {
            auth_request /auth-verify;
            error_page 401 =401 /error401;
            error_page 403 =403 /error403;

            limit_req zone=api_limit burst=20 nodelay;
            proxy_pass http://learning-service:3006;
            
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # ── Routing ke Student Service (DILINDUNGI) ───────────
        location /api/student {
            auth_request /auth-verify;
            error_page 401 =401 /error401;
            error_page 403 =403 /error403;

            limit_req zone=api_limit burst=20 nodelay;
            proxy_pass http://student-service:3008;
            
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # ── Routing ke Vocational Service (DILINDUNGI) ────────
        location /api/vocational {
            auth_request /auth-verify;
            error_page 401 =401 /error401;
            error_page 403 =403 /error403;

            limit_req zone=api_limit burst=20 nodelay;
            proxy_pass http://vocational-service:3007;
            
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # ── Default: Route ke Frontend ────────────────────────
        location / {
            proxy_pass http://frontend;
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        }
    }
}